# Web app (production): https://loglens-ten.vercel.app

# Vite dev proxy (local npm run dev)
VITE_API_PROXY_TARGET=https://api.madhavmaheshwaricreations.in
VITE_INGEST_PROXY_TARGET=https://ingest.madhavmaheshwaricreations.in

# Vercel / static build (no proxy — API must allow CORS for your origin)
# VITE_API_BASE_URL=https://api.madhavmaheshwaricreations.in
# VITE_INGEST_BASE_URL=https://ingest.madhavmaheshwaricreations.in

# Local backend
# VITE_API_PROXY_TARGET=http://localhost:8080
# VITE_INGEST_PROXY_TARGET=http://localhost:8081

# Go SDK (set in your app's environment, not in this frontend .env)
# LOGLENS_API_KEY=ll_...
# INGESTOR_URL=https://ingest.madhavmaheshwaricreations.in
